{
    "name": "json-viewer",
    "version": "1.0.0",
    "private": true,
    "description": "JSON viewer with image gallery, search, text comparer, and history",
    "type": "module",
    "scripts": {
        "build": "esbuild src/app.js --bundle --format=iife --outfile=app.js",
        "dev": "esbuild src/app.js --bundle --format=iife --outfile=app.js --watch",
        "lint": "eslint src",
        "format": "prettier --write \"src/**/*.js\"",
        "format:check": "prettier --check \"src/**/*.js\"",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "@vitest/ui": "^2.1.0",
        "esbuild": "^0.24.0",
        "eslint": "^9.13.0",
        "jsdom": "^25.0.0",
        "prettier": "^3.3.0",
        "vitest": "^2.1.0"
    }
}
